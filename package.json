{
  "name": "lcm-logistics-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Liberty & Liberty Logistics — global logistics & international shipping platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "emulators": "firebase emulators:start --project demo-lcm --only auth,firestore,storage --import=./.emulator-data --export-on-exit",
    "firebase:rules": "firebase deploy --only firestore:rules,storage:rules",
    "firebase:deploy": "next build && firebase deploy"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "firebase": "^10.13.2",
    "firebase-admin": "^12.5.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.16.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.47",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
