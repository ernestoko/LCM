# ============================================================================
# Liberty Cargo Movers Logistics Platform — Environment Configuration
# Copy this file to `.env.local` and fill in your real values.
# ============================================================================

# ---------------------------------------------------------------------------
# Firebase Web SDK (client) — from Firebase Console > Project Settings > General
# These are safe to expose to the browser (NEXT_PUBLIC_*).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Firebase Admin SDK (server only) — from Project Settings > Service Accounts
# Generate a new private key and paste the values. NEVER expose these.
# The private key must keep its \n line breaks (wrap the whole value in quotes).
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# ---------------------------------------------------------------------------
# mNotify SMS (https://readytogo.mnotify.com / https://apps.mnotify.net)
# Used to send tracking + status SMS to customers. Sender ID must be approved.
# ---------------------------------------------------------------------------
MNOTIFY_API_KEY=
MNOTIFY_SENDER_ID=LibertyCM

# ---------------------------------------------------------------------------
# WhatsApp Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
# Optional — used to send WhatsApp tracking/status updates to customers.
# ---------------------------------------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---------------------------------------------------------------------------
# Email notifications (provider-agnostic SMTP / Resend-ready)
# Set EMAIL_PROVIDER=resend and RESEND_API_KEY, OR leave as `console` to log.
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=console
EMAIL_FROM="Liberty Cargo Movers <no-reply@libertycargomovers.com>"
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------------------
# Local emulator preview (optional) — run the whole app with NO cloud project.
# Set USE_FIREBASE_EMULATOR=true, use the demo values above, start the emulators
# (firebase emulators:start --project demo-lcm --only auth,firestore,storage),
# seed with FIRESTORE_EMULATOR_HOST/FIREBASE_AUTH_EMULATOR_HOST set, then run.
# See "Local emulator preview" in SETUP.md.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Assistant identity verification (Jesselyn "verify-before-reveal")
# A strong random secret signs the short-lived tokens that authorise the chat
# assistant to reveal a customer's own shipment details after an OTP check.
# Generate one with:  openssl rand -hex 32
# ASSISTANT_OTP_ECHO returns the code in the API response for EMULATOR testing
# only — never set it to "true" in production.
# ---------------------------------------------------------------------------
ASSISTANT_VERIFY_SECRET=
ASSISTANT_OTP_ECHO=false

# ---------------------------------------------------------------------------
# Optional AI layer for Jesselyn (the assistant). She runs entirely on a local,
# self-updating knowledge base by default — NO AI needed. If you set an Anthropic
# API key, she'll additionally use Claude (grounded in that same knowledge base)
# to answer hard/novel questions; without a key she falls back to her local brain.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (optional "I'm not a robot" gate on the assistant)
# When the secret is set, the verification endpoints require a valid token.
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Platform settings
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Liberty Cargo Movers"
NEXT_PUBLIC_SUPPORT_PHONE="+233 00 000 0000"
NEXT_PUBLIC_SUPPORT_EMAIL="support@libertycargomovers.com"

# Idle-session timeout for STAFF logins, in minutes (0 disables). Customers are
# exempt. After this much inactivity a staff session is signed out for security.
NEXT_PUBLIC_IDLE_TIMEOUT_MIN=60

# ---------------------------------------------------------------------------
# Observability (optional). The error boundaries always log to the console and
# will additionally forward to Sentry if a Sentry SDK is loaded on `window`.
# Set a collection URL to also receive a small JSON beacon per client error.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ERROR_REPORT_URL=
